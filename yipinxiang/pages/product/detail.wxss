/* 产品详情页样式 */
.page {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 产品大图 */
.detail-hero {
  position: relative;
  height: 600rpx;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-back {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  width: 70rpx;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
  line-height: 1;
}

/* 产品主体 */
.detail-body {
  padding: 30rpx;
}

.detail-header {
  background: white;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.detail-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.detail-tags {
  display: flex;
  gap: 10rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 25rpx;
  line-height: 1.6;
}

.detail-price-row {
  display: flex;
  align-items: baseline;
}

/* 规格选择 */
.detail-specs {
  background: white;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.spec-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  padding: 20rpx 30rpx;
  background: #fafafa;
  border-radius: 50rpx;
  border: 2rpx solid transparent;
  text-align: center;
  transition: all 0.3s ease;
  min-width: 200rpx;
}

.spec-item.active {
  background: #fff0f5;
  border-color: #ff6b9d;
}

.spec-label {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.spec-price {
  font-size: 28rpx;
  color: #ff6b9d;
  font-weight: bold;
}

/* 数量选择 */
.detail-quantity {
  background: white;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quantity-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 0;
}

.quantity-btn {
  width: 70rpx;
  height: 70rpx;
  background: #fafafa;
  border: 2rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  transition: all 0.2s ease;
}

.quantity-btn:first-child {
  border-radius: 50rpx 0 0 50rpx;
}

.quantity-btn:last-child {
  border-radius: 0 50rpx 50rpx 0;
}

.quantity-btn:active {
  background: #ffb6c1;
  color: white;
}

.quantity-btn.disabled {
  color: #ccc;
  pointer-events: none;
}

.quantity-input {
  width: 100rpx;
  height: 70rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  border-top: 2rpx solid #eee;
  border-bottom: 2rpx solid #eee;
  background: white;
}

/* 详情内容 */
.detail-section {
  background: white;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #ff6b9d;
}

.detail-text {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
  text-align: justify;
}

/* 评价 */
.detail-reviews {
  background: white;
  border-radius: 30rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.review-card {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-card:last-child {
  border-bottom: none;
}

.review-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.review-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #ffb6c1;
}

.review-user-info {
  flex: 1;
}

.review-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.review-date {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.review-stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #ddd;
}

.star.filled {
  color: #ffa940;
}

.review-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  align-items: center;
  padding: 15rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  height: 110rpx;
  box-sizing: border-box;
}

.bar-left {
  margin-right: 20rpx;
}

.bar-btn {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-icon {
  font-size: 40rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #f44336;
  color: white;
  font-size: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 50%;
  padding: 0 6rpx;
}

.bar-right {
  flex: 1;
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-add-cart {
  background: linear-gradient(135deg, #ffb6c1, #ff6b9d);
  color: white;
}

.btn-buy-now {
  background: linear-gradient(135deg, #ff6b9d, #ff4081);
  color: white;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}