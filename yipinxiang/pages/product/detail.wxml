<!-- 产品详情页 -->
<view class="page">
  <!-- 产品大图 -->
  <view class="detail-hero">
    <image class="hero-img" src="{{product.image}}" mode="aspectFill" />
    <view class="hero-back" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
  </view>

  <!-- 产品信息 -->
  <view class="detail-body">
    <view class="detail-header">
      <view class="detail-name-row">
        <text class="detail-name">{{product.name}}</text>
        <view class="detail-tags">
          <text class="tag tag-hot" wx:if="{{product.isHot}}">热卖</text>
          <text class="tag tag-new" wx:if="{{product.isNew}}">新品</text>
        </view>
      </view>
      <text class="detail-desc">{{product.desc}}</text>
      <view class="detail-price-row">
        <text class="price">¥{{selectedSpec ? selectedSpec.price : product.price}}</text>
        <text class="price-original" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</text>
      </view>
    </view>

    <!-- 规格选择 -->
    <view class="detail-specs">
      <view class="spec-title">选择规格</view>
      <view class="spec-list">
        <view class="spec-item {{specIndex === index ? 'active' : ''}}" 
              wx:for="{{product.specs}}" wx:key="index"
              bindtap="selectSpec" data-index="{{index}}">
          <text class="spec-label">{{item.label}}</text>
          <text class="spec-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>

    <!-- 数量选择 -->
    <view class="detail-quantity">
      <view class="quantity-title">购买数量</view>
      <view class="quantity-control">
        <view class="quantity-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="reduceQuantity">-</view>
        <input class="quantity-input" type="number" value="{{quantity}}" disabled />
        <view class="quantity-btn" bindtap="addQuantity">+</view>
      </view>
    </view>

    <!-- 产品详情 -->
    <view class="detail-section">
      <view class="section-title">产品详情</view>
      <view class="detail-content">
        <text class="detail-text">{{product.detail}}</text>
      </view>
    </view>

    <!-- 用户评价（示例） -->
    <view class="detail-reviews">
      <view class="section-title">用户评价 ({{reviews.length}})</view>
      <view class="review-card" wx:for="{{reviews}}" wx:key="index">
        <view class="review-header">
          <image class="review-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view class="review-user-info">
            <text class="review-name">{{item.name}}</text>
            <text class="review-date">{{item.date}}</text>
          </view>
          <view class="review-stars">
            <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" 
                  class="star {{*this <= item.rating ? 'filled' : ''}}">★</text>
          </view>
        </view>
        <text class="review-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="bar-left">
      <view class="bar-btn" bindtap="goToCart">
        <text class="bar-icon">🛒</text>
        <text class="bar-label">购物车</text>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
    </view>
    <view class="bar-right">
      <view class="btn btn-add-cart" bindtap="addToCart">加入购物车</view>
      <view class="btn btn-buy-now" bindtap="buyNow">立即购买</view>
    </view>
  </view>
</view>