<!-- 首页 -->
<view class="page">
  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots="true" autoplay="true" interval="4000" duration="500" circular="true">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
      <view class="banner-text">{{item.title}}</view>
    </swiper-item>
  </swiper>

  <!-- 店铺信息卡片 -->
  <view class="shop-card card">
    <view class="shop-header">
      <image class="shop-logo" src="/images/shop-logo.png" mode="aspectFill" />
      <view class="shop-info">
        <text class="shop-name">一品香蛋糕房</text>
        <text class="shop-desc">用心烘焙，甜蜜每一刻</text>
        <view class="shop-tags">
          <text class="tag tag-hot">人气店铺</text>
          <text class="tag tag-new">新品上市</text>
        </view>
      </view>
    </view>
    <view class="shop-stats">
      <view class="stat-item">
        <text class="stat-num">128</text>
        <text class="stat-label">精选产品</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">4.9</text>
        <text class="stat-label">用户评分</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">30min</text>
        <text class="stat-label">极速配送</text>
      </view>
    </view>
  </view>

  <!-- 分类导航 -->
  <view class="category-nav">
    <view class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
          wx:for="{{categories}}" wx:key="id" 
          bindtap="switchCategory" data-id="{{item.id}}">
      <image class="category-icon" src="{{item.icon}}" mode="aspectFit" />
      <text class="category-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 产品列表 -->
  <view class="product-section">
    <view class="section-title">
      <text class="title-text">{{currentCategoryName}}</text>
      <text class="title-sub">为您精选</text>
    </view>
    
    <view class="product-grid">
      <view class="product-card card" wx:for="{{filteredProducts}}" wx:key="id" 
            bindtap="goToDetail" data-id="{{item.id}}">
        <view class="product-img-wrap">
          <image class="product-img" src="{{item.image}}" mode="aspectFill" />
          <view class="product-tag tag tag-hot" wx:if="{{item.isHot}}">热卖</view>
          <view class="product-tag tag tag-new" wx:if="{{item.isNew}}">新品</view>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.desc}}</text>
          <view class="product-bottom">
            <view class="product-price">
              <text class="price">¥{{item.price}}</text>
              <text class="price-original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
            </view>
            <view class="add-cart-btn" catchtap="quickAddCart" data-item="{{item}}">
              <text class="add-icon">+</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 小程序码入口 -->
  <view class="qrcode-section card">
    <view class="qrcode-title">扫码进入小程序</view>
    <view class="qrcode-desc">分享给好友，一起享受甜蜜时光</view>
    <image class="qrcode-img" src="/images/miniprogram-code.png" mode="aspectFit" />
    <view class="qrcode-tip">长按识别小程序码</view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">一品香蛋糕房 © 2026</text>
    <text class="footer-text">用心烘焙，甜蜜每一刻</text>
  </view>
</view>