/* 首页样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff9f9 0%, #ffffff 100%);
}

/* 轮播图 */
.banner {
  height: 400rpx;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-text {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  padding: 20rpx;
  border-radius: 20rpx;
}

/* 店铺卡片 */
.shop-card {
  margin: -60rpx 30rpx 30rpx;
  position: relative;
  z-index: 10;
  border-top: 8rpx solid #ff6b9d;
}

.shop-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.shop-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffb6c1;
  margin-right: 30rpx;
}

.shop-info {
  flex: 1;
}

.shop-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.shop-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.shop-tags {
  display: flex;
  gap: 15rpx;
}

.shop-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b9d;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 分类导航 */
.category-nav {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background: white;
  border-radius: 30rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.category-item.active {
  background: linear-gradient(135deg, #ffb6c1, #ff6b9d);
  transform: translateY(-10rpx);
}

.category-item.active .category-name {
  color: white;
}

.category-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 15rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 产品区域 */
.product-section {
  padding: 0 30rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}

.title-text::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 30rpx;
  background: linear-gradient(to bottom, #ff6b9d, #ffb6c1);
  border-radius: 3rpx;
}

.title-sub {
  font-size: 26rpx;
  color: #999;
}

/* 产品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  overflow: hidden;
  transition: all 0.3s ease;
}

.product-card:active {
  transform: scale(0.98);
}

.product-img-wrap {
  position: relative;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-img {
  width: 100%;
  height: 100%;
}

.product-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 2;
}

.product-info {
  padding: 0 10rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
  height: 68rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.add-cart-btn {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #ff6b9d, #ff4081);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 157, 0.3);
  transition: all 0.3s ease;
}

.add-cart-btn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 157, 0.2);
}

/* 小程序码区域 */
.qrcode-section {
  text-align: center;
  margin: 50rpx 30rpx;
  padding: 40rpx;
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.qrcode-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.qrcode-img {
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 30rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 20rpx;
  background: white;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #999;
  font-style: italic;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #ffffff, #fff9f9);
  border-top: 2rpx solid #f0f0f0;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}