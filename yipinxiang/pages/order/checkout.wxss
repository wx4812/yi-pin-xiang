/* 结算页面样式 */
.page {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 140rpx;
}

/* 地址卡片 */
.address-card {
  margin: 30rpx;
  cursor: pointer;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.address-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.address-arrow {
  font-size: 36rpx;
  color: #999;
  font-weight: 300;
}

.address-content {
  padding-left: 50rpx;
}

.address-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.address-empty {
  padding-left: 50rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 订单区域 */
.order-section {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #ff6b9d;
}

.order-product {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-product:last-child {
  border-bottom: none;
}

.op-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 15rpx;
  margin-right: 20rpx;
}

.op-info {
  flex: 1;
}

.op-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.op-spec {
  font-size: 24rpx;
  color: #999;
}

.op-right {
  text-align: right;
}

.op-quantity {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 订单信息 */
.order-info {
  margin-top: 15rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item.total {
  padding-top: 25rpx;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 备注 */
.remark-input {
  width: 100%;
  min-height: 150rpx;
  font-size: 26rpx;
  color: #333;
  background: #fafafa;
  border-radius: 15rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bar-left {
  flex: 1;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
}

.submit-btn {
  width: 220rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 50rpx;
}