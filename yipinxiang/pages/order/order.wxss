/* 订单页面样式 */
.page {
  min-height: 100vh;
  background: #fafafa;
}

/* 头部 */
.order-header {
  background: linear-gradient(135deg, #ff6b9d, #ff4081);
  padding: 30rpx;
  color: white;
  border-radius: 0 0 40rpx 40rpx;
}

.order-title {
  font-size: 36rpx;
  font-weight: bold;
}

/* 状态切换 */
.order-tabs {
  display: flex;
  background: white;
  margin: 30rpx;
  border-radius: 50rpx;
  padding: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 157, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 50rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #ff6b9d, #ff4081);
  color: white;
  font-weight: bold;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 157, 0.3);
}

/* 空订单 */
.empty {
  text-align: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #ffb6c1;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 50rpx;
}

.go-btn {
  width: 300rpx;
  margin: 0 auto;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 30rpx 30rpx;
}

.order-card {
  margin-bottom: 30rpx;
  padding: 0;
  overflow: hidden;
}

.order-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
  background: #fff9f9;
}

.order-id {
  font-size: 24rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.status-pending {
  color: #ff9800;
  background: #fff3e0;
}

.status-shipped {
  color: #2196f3;
  background: #e3f2fd;
}

.status-done {
  color: #4caf50;
  background: #e8f5e9;
}

/* 订单产品列表 */
.order-products {
  padding: 0 30rpx;
}

.order-product {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-product:last-child {
  border-bottom: none;
}

.op-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 15rpx;
  margin-right: 20rpx;
}

.op-info {
  flex: 1;
}

.op-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.op-spec {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.op-right {
  text-align: right;
}

.op-quantity {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 订单底部 */
.order-card-footer {
  padding: 25rpx 30rpx;
  background: #fafafa;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-total {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}