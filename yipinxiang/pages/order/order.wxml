<!-- 订单页面 -->
<view class="page">
  <!-- 头部 -->
  <view class="order-header">
    <text class="order-title">我的订单</text>
  </view>

  <!-- 订单状态切换 -->
  <view class="order-tabs">
    <view class="tab-item {{currentTab === index ? 'active' : ''}}" 
          wx:for="{{tabs}}" wx:key="index" 
          bindtap="switchTab" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <!-- 空订单 -->
  <view class="empty" wx:if="{{filteredOrders.length === 0}}">
    <view class="empty-icon">📋</view>
    <text class="empty-text">暂无订单</text>
    <text class="empty-sub">快去挑选心仪的甜品吧</text>
    <view class="btn btn-primary go-btn" bindtap="goShopping">去逛逛</view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:else>
    <view class="order-card card" wx:for="{{filteredOrders}}" wx:key="id">
      <view class="order-card-header">
        <text class="order-id">订单号：{{item.id}}</text>
        <text class="order-status {{item.status === '待发货' ? 'status-pending' : ''}} {{item.status === '已发货' ? 'status-shipped' : ''}} {{item.status === '已完成' ? 'status-done' : ''}}">
          {{item.status}}
        </text>
      </view>

      <view class="order-products">
        <view class="order-product" wx:for="{{item.products}}" wx:for-item="product" wx:key="*this">
          <image class="op-img" src="{{product.image}}" mode="aspectFill" />
          <view class="op-info">
            <text class="op-name">{{product.name}}</text>
            <text class="op-spec">{{product.spec}}</text>
          </view>
          <view class="op-right">
            <text class="price">¥{{product.price}}</text>
            <text class="op-quantity">×{{product.quantity}}</text>
          </view>
        </view>
      </view>

      <view class="order-card-footer">
        <text class="order-time">{{item.createTime}}</text>
        <text class="order-total">共{{item.totalCount}}件商品 合计：<text class="price">¥{{item.totalPrice}}</text></text>
      </view>
    </view>
  </view>
</view>