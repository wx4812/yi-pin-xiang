<!-- 结算页面 -->
<view class="page">
  <!-- 收货地址 -->
  <view class="address-card card" bindtap="selectAddress">
    <view class="address-header">
      <text class="address-icon">📍</text>
      <text class="address-title">收货地址</text>
      <text class="address-arrow">›</text>
    </view>
    <view class="address-content" wx:if="{{address}}">
      <text class="address-name">{{address.name}} {{address.phone}}</text>
      <text class="address-detail">{{address.detail}}</text>
    </view>
    <view class="address-empty" wx:else>
      <text class="empty-text">请选择收货地址</text>
    </view>
  </view>

  <!-- 商品清单 -->
  <view class="order-section card">
    <view class="section-title">商品清单</view>
    <view class="order-products">
      <view class="order-product" wx:for="{{orderItems}}" wx:key="*this">
        <image class="op-img" src="{{item.image}}" mode="aspectFill" />
        <view class="op-info">
          <text class="op-name">{{item.name}}</text>
          <text class="op-spec">{{item.spec}}</text>
        </view>
        <view class="op-right">
          <text class="price">¥{{item.price}}</text>
          <text class="op-quantity">×{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="order-section card">
    <view class="section-title">订单信息</view>
    <view class="order-info">
      <view class="info-item">
        <text class="info-label">商品金额</text>
        <text class="info-value">¥{{totalPrice}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">配送费</text>
        <text class="info-value">¥{{deliveryFee}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">优惠券</text>
        <text class="info-value">-¥{{discount}}</text>
      </view>
      <view class="info-item total">
        <text class="info-label">实付金额</text>
        <text class="price info-value">¥{{actualPrice}}</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="order-section card">
    <view class="section-title">订单备注</view>
    <textarea class="remark-input" placeholder="选填：请输入备注信息" 
              value="{{remark}}" bindinput="onRemarkInput" 
              maxlength="100" auto-height />
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="bar-left">
      <text class="total-label">合计：</text>
      <text class="price total-price">¥{{actualPrice}}</text>
    </view>
    <view class="btn btn-primary submit-btn" bindtap="submitOrder">提交订单</view>
  </view>
</view>