<!-- 购物车页面 -->
<view class="page">
  <!-- 头部 -->
  <view class="cart-header">
    <text class="cart-title">购物车</text>
    <text class="cart-clear" bindtap="clearCart" wx:if="{{cartItems.length > 0}}">清空</text>
  </view>

  <!-- 空购物车 -->
  <view class="empty" wx:if="{{cartItems.length === 0}}">
    <view class="empty-icon">🛒</view>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-sub">快去挑选心仪的甜品吧</text>
    <view class="btn btn-primary go-shopping-btn" bindtap="goShopping">去逛逛</view>
  </view>

  <!-- 购物车列表 -->
  <block wx:else>
    <view class="cart-list">
      <view class="cart-item card" wx:for="{{cartItems}}" wx:key="uniqueId">
        <!-- 选择框 -->
        <view class="cart-checkbox" bindtap="toggleSelect" data-index="{{index}}">
          <view class="checkbox {{item.selected ? 'checked' : ''}}">
            <text class="check-icon" wx:if="{{item.selected}}">✓</text>
          </view>
        </view>

        <!-- 商品图片 -->
        <image class="cart-item-img" src="{{item.image}}" mode="aspectFill" />

        <!-- 商品信息 -->
        <view class="cart-item-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-spec">{{item.spec}}</text>
          <view class="cart-item-bottom">
            <text class="price">¥{{item.price}}</text>
            <view class="cart-quantity-control">
              <view class="cart-qbtn" bindtap="reduceItem" data-index="{{index}}">-</view>
              <input class="cart-qnum" value="{{item.quantity}}" disabled />
              <view class="cart-qbtn" bindtap="addItem" data-index="{{index}}">+</view>
            </view>
          </view>
        </view>

        <!-- 删除按钮 -->
        <view class="cart-delete" bindtap="deleteItem" data-index="{{index}}">
          <text>×</text>
        </view>
      </view>
    </view>

    <!-- 底部结算栏 -->
    <view class="cart-footer">
      <view class="footer-select" bindtap="toggleAll">
        <view class="checkbox {{allSelected ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{allSelected}}">✓</text>
        </view>
        <text class="select-text">全选</text>
      </view>
      <view class="footer-info">
        <text class="footer-label">合计：</text>
        <text class="price footer-price">¥{{totalPrice}}</text>
      </view>
      <view class="btn btn-primary checkout-btn {{totalPrice === '0.00' ? 'disabled' : ''}}" 
            bindtap="checkout">
        结算 ({{selectedCount}})
      </view>
    </view>
  </block>
</view>