/* 购物车页面样式 */
.page {
  min-height: 100vh;
  background: #fafafa;
  padding-bottom: 120rpx;
}

/* 头部 */
.cart-header {
  background: linear-gradient(135deg, #ff6b9d, #ff4081);
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: white;
  border-radius: 0 0 40rpx 40rpx;
}

.cart-title {
  font-size: 36rpx;
  font-weight: bold;
}

.cart-clear {
  font-size: 28rpx;
  opacity: 0.9;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

/* 空购物车 */
.empty {
  text-align: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #ffb6c1;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 50rpx;
}

.go-shopping-btn {
  width: 300rpx;
  margin: 0 auto;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

/* 购物车列表 */
.cart-list {
  padding: 30rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.cart-checkbox {
  margin-right: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: #ff6b9d;
  border-color: #ff6b9d;
}

.check-icon {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.cart-item-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.cart-item-info {
  flex: 1;
}

.cart-item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-item-spec {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.cart-item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-quantity-control {
  display: flex;
  align-items: center;
  gap: 0;
  border: 2rpx solid #eee;
  border-radius: 50rpx;
  overflow: hidden;
}

.cart-qbtn {
  width: 60rpx;
  height: 60rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  transition: all 0.2s ease;
}

.cart-qbtn:first-child {
  border-right: 2rpx solid #eee;
}

.cart-qbtn:last-child {
  border-left: 2rpx solid #eee;
}

.cart-qbtn:active {
  background: #ffb6c1;
  color: white;
}

.cart-qnum {
  width: 80rpx;
  height: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  background: white;
}

.cart-delete {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 50rpx;
  height: 50rpx;
  background: #fafafa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  transition: all 0.3s ease;
}

.cart-delete:active {
  background: #ff6b9d;
  color: white;
}

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.footer-select {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
}

.select-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 15rpx;
}

.footer-info {
  flex: 1;
  text-align: right;
  margin-right: 30rpx;
}

.footer-label {
  font-size: 28rpx;
  color: #333;
}

.footer-price {
  font-size: 36rpx;
  font-weight: bold;
}

.checkout-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 50rpx;
}

.checkout-btn.disabled {
  background: #ccc;
  pointer-events: none;
}