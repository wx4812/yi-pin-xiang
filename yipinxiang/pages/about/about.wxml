<!-- 关于我们 / 个人中心 -->
<view class="page">
  <!-- 用户信息卡片 -->
  <view class="user-hero">
    <view class="user-avatar-wrap">
      <image class="user-avatar" src="/images/shop-logo.png" mode="aspectFill" />
    </view>
    <text class="user-name">一品香蛋糕房</text>
    <text class="user-desc">用心烘焙，甜蜜每一刻</text>
    <view class="user-stats">
      <view class="ustat-item">
        <text class="ustat-num">{{orderCount}}</text>
        <text class="ustat-label">全部订单</text>
      </view>
      <view class="ustat-item">
        <text class="ustat-num">{{pendingCount}}</text>
        <text class="ustat-label">待发货</text>
      </view>
      <view class="ustat-item">
        <text class="ustat-num">{{doneCount}}</text>
        <text class="ustat-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能介绍 -->
  <view class="about-section card">
    <view class="section-title">店铺介绍</view>
    <view class="about-content">
      <text class="about-text">一品香蛋糕房成立于2018年，是一家专注于精品蛋糕和烘焙甜点的品牌店铺。我们坚持"用心烘焙，甜蜜每一刻"的理念，精选优质原料，纯手工制作，为顾客带来健康、美味、精致的烘焙体验。</text>
      <view class="about-highlights">
        <view class="highlight-item" wx:for="{{highlights}}" wx:key="index">
          <text class="highlight-icon">{{item.icon}}</text>
          <text class="highlight-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 联系我们 -->
  <view class="about-section card">
    <view class="section-title">联系我们</view>
    <view class="contact-list">
      <view class="contact-item">
        <text class="contact-icon">📍</text>
        <text class="contact-text">广州市天河区花城大道88号</text>
      </view>
      <view class="contact-item">
        <text class="contact-icon">📞</text>
        <text class="contact-text">020-8888-6666</text>
      </view>
      <view class="contact-item">
        <text class="contact-icon">🕐</text>
        <text class="contact-text">营业时间：8:00 - 22:00</text>
      </view>
      <view class="contact-item">
        <text class="contact-icon">📧</text>
        <text class="contact-text">service@yipinxiang.com</text>
      </view>
    </view>
  </view>

  <!-- 小程序码 -->
  <view class="qrcode-section card">
    <view class="section-title">分享小程序</view>
    <view class="qrcode-desc">让更多人知道一品香蛋糕房</view>
    <image class="qrcode-img" src="/images/miniprogram-code.png" mode="aspectFit" />
    <view class="qrcode-tip">长按识别小程序码 · 进入一品香</view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text class="footer-text">一品香蛋糕房 © 2026</text>
    <text class="footer-text">用心烘焙，甜蜜每一刻</text>
  </view>
</view>