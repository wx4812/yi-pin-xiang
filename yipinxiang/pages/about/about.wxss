/* 关于我们页面样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff9f9 0%, #fafafa 100%);
}

/* 用户信息卡片 */
.user-hero {
  background: linear-gradient(165deg, #ff6b9d 0%, #ff4081 50%, #ffb6c1 100%);
  padding: 60rpx 30rpx 40rpx;
  border-radius: 0 0 60rpx 60rpx;
  text-align: center;
  color: white;
}

.user-avatar-wrap {
  width: 150rpx;
  height: 150rpx;
  margin: 0 auto 25rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(255, 64, 129, 0.3);
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 40rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 30rpx;
  margin: 0 20rpx;
}

.ustat-item {
  text-align: center;
}

.ustat-num {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.ustat-label {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-top: 8rpx;
}

/* 介绍区域 */
.about-section {
  margin: 30rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #ff6b9d;
}

.about-text {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
  text-align: justify;
}

.about-highlights {
  display: flex;
  justify-content: space-around;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.highlight-item {
  text-align: center;
}

.highlight-icon {
  font-size: 50rpx;
  display: block;
  margin-bottom: 15rpx;
}

.highlight-label {
  font-size: 24rpx;
  color: #666;
}

/* 联系列表 */
.contact-list {
  margin-top: 10rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #555;
}

/* 小程序码 */
.qrcode-section {
  text-align: center;
  margin: 30rpx;
  padding: 40rpx;
}

.qrcode-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.qrcode-img {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 25rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 20rpx;
  background: white;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #999;
  font-style: italic;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 30rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}